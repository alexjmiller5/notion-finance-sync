# notion-finance-sync — NON-SECRET runtime env (deploy overrides + server knobs).
#
# Copy to .env (which is gitignored):   cp .env.example .env
#
# Personal identifiers (Gmail address, Bilt phone, Notion IDs, 1Password vault)
# now live in config.toml — see config.example.toml. Secrets live in 1Password;
# the OP service-account token lives in the macOS Keychain (`just store-op-token`).
# This file is only deploy/runtime knobs, safe if it ever leaks.

# Keychain service name holding the OP service-account token
# (read by deploy/run_sync.sh on the Mac Mini).
OP_TOKEN_KEYCHAIN_SERVICE=notion-finance-sync-op-token

# FastAPI server settings (pydantic-settings AppSettings, APP_ prefix)
APP_SERVER_HOST=127.0.0.1
APP_SERVER_PORT=8765
APP_LOG_LEVEL=INFO
