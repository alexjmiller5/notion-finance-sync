# notion-finance-sync — NON-SECRET runtime config.
#
# Copy to .env (which is gitignored):   cp .env.example .env
#
# ⚠️ DO NOT put secrets here. All real secrets are read from 1Password at runtime,
# and the 1Password service-account TOKEN lives in the macOS Keychain, not here
# (store it with `just store-op-token`). This file is only for non-sensitive
# config so it's safe if it ever leaks.

# Gmail address for email-2FA IMAP. REQUIRED (no default — keeps personal email
# out of source control). Set your real address in .env (gitignored), not here.
GMAIL_ADDRESS=you@gmail.com

# Bilt login phone number (10 digits) — Bilt auths by SMS OTP, no username/password.
BILT_PHONE=5551234567

# Keychain service name holding the OP service-account token
# (read by deploy/run_sync.sh on the Mac Mini).
OP_TOKEN_KEYCHAIN_SERVICE=notion-finance-sync-op-token

# FastAPI server settings (pydantic-settings AppSettings, APP_ prefix)
APP_SERVER_HOST=127.0.0.1
APP_SERVER_PORT=8765
APP_LOG_LEVEL=INFO
